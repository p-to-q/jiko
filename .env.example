# Runtime selection
APP_RUNTIME=laptop
STT_PROVIDER=sherpa-onnx
TTS_PROVIDER=clip
RECEIPTS_ENABLED=1
SAVE_RAW_AUDIO=0
SAVE_WORKING_AUDIO=0

# Local server
PORT=4317
EVENT_STREAM_PATH=/events
JIKO_WRITE_RECEIPTS=1

# Local/self-hosted speech services
FUNASR_ENDPOINT=http://127.0.0.1:10095
PIPER_BIN=piper
PIPER_VOICE=
TTS_CLIP_DIR=local-clips
TTS_PLAY_AUDIO=0
TTS_PLAY_COMMAND=
TTS_GENERATE_COMMAND=say
TTS_GENERATE_VOICE=
TTS_GENERATE_EXTENSION=
TTS_GENERATE_ARGS=
# Local STT via whisper.cpp. Set STT_PROVIDER=whisper.cpp and point these at a
# whisper.cpp build + ggml model. The server loads apps/server/.env automatically
# (node --env-file-if-exists). Example (sibling whisper.cpp build):
#   STT_PROVIDER=whisper.cpp
#   WHISPER_CPP_BIN=/abs/path/to/whisper.cpp/build/bin/whisper-cli
#   WHISPER_MODEL=/abs/path/to/whisper.cpp/models/ggml-large-v3-turbo.bin
WHISPER_CPP_BIN=
WHISPER_MODEL=
# 'auto' detects language; 'zh' pins Simplified Chinese.
WHISPER_LANGUAGE=auto
SHERPA_ONNX_PYTHON=.venv/bin/python
SHERPA_ONNX_SENSEVOICE_MODEL=/path/to/sherpa-sensevoice/model.onnx
SHERPA_ONNX_SENSEVOICE_TOKENS=/path/to/sherpa-sensevoice/tokens.txt
SHERPA_ONNX_LANGUAGE=auto
SHERPA_ONNX_THREADS=4
SHERPA_ONNX_PROVIDER=cpu
SHERPA_ONNX_USE_ITN=1
FFMPEG_BIN=ffmpeg

# Manual/demo fallback
MANUAL_PROVIDER_ENABLED=1
DEMO_OPERATOR_KEY=

# Public site waitlist storage. Use a hosted Postgres/Neon URL in Vercel env.
DATABASE_URL=
POSTGRES_URL=
WAITLIST_BASE_COUNT=0
# Secret for GET /api/waitlist-admin (Bearer token or ?secret=). Set in Vercel env.
ADMIN_SECRET=

# Raspberry Pi hardware adapter
GPIO_RECORD_BUTTON_PIN=17
AUDIO_INPUT_DEVICE=
AUDIO_OUTPUT_DEVICE=
