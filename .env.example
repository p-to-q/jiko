# Runtime selection
APP_RUNTIME=laptop
STT_PROVIDER=funasr
TTS_PROVIDER=piper
RECEIPTS_ENABLED=1
SAVE_RAW_AUDIO=0
SAVE_WORKING_AUDIO=0

# Local server
PORT=4317
EVENT_STREAM_PATH=/events
JIKO_WRITE_RECEIPTS=1

# Local/self-hosted speech services
FUNASR_ENDPOINT=http://127.0.0.1:10095
PIPER_BIN=piper
PIPER_VOICE=
TTS_CLIP_DIR=apps/server/local-clips
TTS_PLAY_AUDIO=0
TTS_PLAY_COMMAND=
TTS_GENERATE_COMMAND=say
TTS_GENERATE_VOICE=
TTS_GENERATE_EXTENSION=
TTS_GENERATE_ARGS=
WHISPER_CPP_BIN=
WHISPER_MODEL=
FFMPEG_BIN=ffmpeg

# Manual/demo fallback
MANUAL_PROVIDER_ENABLED=1
DEMO_OPERATOR_KEY=

# Raspberry Pi hardware adapter
GPIO_RECORD_BUTTON_PIN=17
AUDIO_INPUT_DEVICE=
AUDIO_OUTPUT_DEVICE=
