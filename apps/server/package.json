{
  "name": "@jiko/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "../../node_modules/.bin/tsc -p tsconfig.json && node --env-file-if-exists=.env dist/index.js",
    "dev:watch": "../../node_modules/.bin/tsc -p tsconfig.json && node --watch --env-file-if-exists=.env dist/index.js",
    "start": "../../node_modules/.bin/tsc -p tsconfig.json && node --env-file-if-exists=.env dist/index.js",
    "build": "../../node_modules/.bin/tsc -p tsconfig.json",
    "typecheck": "../../node_modules/.bin/tsc -p tsconfig.json --noEmit",
    "generate:clips": "node scripts/generate-local-clips.mjs"
  },
  "dependencies": {
    "@jiko/core": "workspace:*",
    "@jiko/protocol": "workspace:*",
    "@jiko/readings": "workspace:*"
  },
  "engines": {
    "node": ">=22"
  }
}
